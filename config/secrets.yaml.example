# Stock Analyzer Configuration Example
# Copy this file to secrets.yaml and fill in your values
# NEVER commit secrets.yaml to Git!

# Reddit API (optional - for collecting Reddit sentiment)
reddit:
  client_id: "your_reddit_client_id"
  client_secret: "your_reddit_client_secret"
  user_agent: "StockAnalyzer/1.0 by your_username"

# Telegram Bot (optional - for sending notifications)
telegram:
  bot_token: "your_telegram_bot_token"
  chat_id: "your_telegram_chat_id"

# Alpha Vantage API (optional - for additional price data)
alpha_vantage:
  api_key: "your_alpha_vantage_api_key"

# Note: For GitHub Actions, set these as GitHub Secrets instead:
# - TELEGRAM_BOT_TOKEN
# - TELEGRAM_CHAT_ID
# - REDDIT_CLIENT_ID
# - REDDIT_CLIENT_SECRET
# - REDDIT_USER_AGENT
